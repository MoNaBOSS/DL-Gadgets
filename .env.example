# Public storefront URL. Use the final HTTPS domain in Vercel production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public contact fallbacks
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_CONTACT_EMAIL=

# Resend order notifications (server-only)
RESEND_API_KEY=
ORDER_NOTIFICATION_EMAIL=
RESEND_FROM_EMAIL="DL Gadgets Orders <orders@your-verified-domain.com>"

# Sanity storefront read + embedded Studio configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=

# Stripe Checkout and verified webhooks (server-only except publishable key)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
